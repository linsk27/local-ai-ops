# Runtime
APP_ENV=local
APP_NAME=Local AI Ops
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Allows browser access from private LAN addresses such as http://192.168.1.20:5173.
CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|10(\.\d{1,3}){3}|192\.168(\.\d{1,3}){2}|172\.(1[6-9]|2[0-9]|3[0-1])(\.\d{1,3}){2})(:[0-9]+)?$

# Database and queue
DATABASE_URL=postgresql+psycopg://aiops:aiops@postgres:5432/aiops
REDIS_URL=redis://redis:6379/0

# Security
# Generate with: python -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
MASTER_KEY=

# Alibaba Cloud
# This product build runs in real Alibaba Cloud mode only.
ALIYUN_MODE=real
ALIYUN_DEFAULT_REGION=cn-hangzhou

# OpenAI-compatible diagnostics
# Prefer configuring these from the in-app AI Config page. These are fallback values.
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=gpt-4.1-mini

# Frontend
# Leave empty for LAN mode. The frontend will call http://<current-host>:8000/api.
VITE_API_BASE_URL=
